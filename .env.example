# Garnet Cache Configuration
# Copy this file to .env and customize for your environment

# Memory Configuration
GARNET_MEMORY_SIZE=128m      # Total cache memory (128m, 256m, 512m, 1g, etc.)
GARNET_INDEX_SIZE=16m        # Initial index size (grows up to GARNET_INDEX_MAX_SIZE)
GARNET_INDEX_MAX_SIZE=64m    # Maximum index before eviction

# Optional: Security (uncomment to enable)
# GARNET_PASSWORD=your-secure-password-here
# GARNET_TLS_ENABLED=false

# Optional: Advanced Tuning
# GARNET_REVIVIFY=true       # Automatic memory recovery (enabled by default)
# GARNET_LOGLEVEL=notice     # Log level (debug, verbose, notice, warning)

# Optional: Storage Tier (for datasets larger than memory)
# GARNET_STORAGE_TIER=false
# GARNET_CHECKPOINT_DIR=/config/garnet/checkpoints

# Example Production Configurations:

# Small Home (100K cached entries)
# GARNET_MEMORY_SIZE=256m
# GARNET_INDEX_SIZE=2m
# GARNET_INDEX_MAX_SIZE=8m

# Large Home (1M cached entries)
# GARNET_MEMORY_SIZE=512m
# GARNET_INDEX_SIZE=16m
# GARNET_INDEX_MAX_SIZE=32m

# Small Business (5M cached entries)
# GARNET_MEMORY_SIZE=1g
# GARNET_INDEX_SIZE=80m
# GARNET_INDEX_MAX_SIZE=200m

# Large Business / Enterprise (10M+ cached entries)
# GARNET_MEMORY_SIZE=2g
# GARNET_INDEX_SIZE=160m
# GARNET_INDEX_MAX_SIZE=512m

# Memory Sizing Formula:
# Total Memory = Log Memory (128m fixed) + Index Memory
# Index Memory = (Number of Keys) × 16 bytes
# Example: 10M keys = 10M × 16 bytes = 160MB
#          Total = 128m + 160m = 288MB → set GARNET_MEMORY_SIZE=512m for headroom
